<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8"/>
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title><%= title %> | PushNotify</title>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet"/>
  <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" rel="stylesheet"/>
  <link rel="stylesheet" href="/css/style.css"/>
</head>
<body>
<%- include('../partials/sidebar') %>
<div class="main-content">
  <%- include('../partials/topbar') %>
  <div class="page-body">
    <%- include('../partials/flash') %>

    <div class="card">
      <div class="card-header">
        <h3><i class="fas fa-users"></i> All Users</h3>
        <div class="card-header-actions">
          <input type="text" id="searchInput" class="form-control form-control-sm" placeholder="Search users..." oninput="filterTable()"/>
        </div>
      </div>
      <div class="card-body p-0">
        <table class="table" id="usersTable">
          <thead>
            <tr>
              <th>#</th>
              <th>Name</th>
              <th>Email</th>
              <th>Role</th>
              <th>Push Notifications</th>
              <th>Status</th>
              <th>Joined</th>
              <th>Actions</th>
            </tr>
          </thead>
          <tbody>
            <% users.forEach((u, i) => { %>
            <tr>
              <td><%= i + 1 %></td>
              <td>
                <div class="user-cell">
                  <div class="mini-avatar"><%= u.name.charAt(0) %></div>
                  <%= u.name %>
                </div>
              </td>
              <td><%= u.email %></td>
              <td><span class="badge <%= u.role === 'admin' ? 'badge-primary' : 'badge-muted' %>"><%= u.role %></span></td>
              <td>
                <span class="badge <%= u.has_subscription > 0 ? 'badge-success' : 'badge-muted' %>">
                  <i class="fas fa-<%= u.has_subscription > 0 ? 'bell' : 'bell-slash' %>"></i>
                  <%= u.has_subscription > 0 ? 'Subscribed' : 'Not Subscribed' %>
                </span>
              </td>
              <td><span class="badge <%= u.is_active ? 'badge-success' : 'badge-danger' %>"><%= u.is_active ? 'Active' : 'Inactive' %></span></td>
              <td><%= new Date(u.created_at).toLocaleDateString() %></td>
              <td>
                <div class="action-btns">
                  <% if (u.role !== 'admin') { %>
                    <a href="/admin/send-notification?type=individual&user_id=<%= u.id %>" class="btn btn-primary btn-xs" title="Send Notification">
                      <i class="fas fa-paper-plane"></i>
                    </a>
                    <form action="/admin/users/toggle/<%= u.id %>" method="POST" style="display:inline">
                      <button type="submit" class="btn <%= u.is_active ? 'btn-warning' : 'btn-success' %> btn-xs" title="<%= u.is_active ? 'Deactivate' : 'Activate' %>">
                        <i class="fas fa-<%= u.is_active ? 'ban' : 'check' %>"></i>
                      </button>
                    </form>
                  <% } %>
                </div>
              </td>
            </tr>
            <% }) %>
          </tbody>
        </table>
      </div>
    </div>
  </div>
</div>
<script>
function filterTable() {
  const q = document.getElementById('searchInput').value.toLowerCase();
  document.querySelectorAll('#usersTable tbody tr').forEach(row => {
    row.style.display = row.textContent.toLowerCase().includes(q) ? '' : 'none';
  });
}
</script>
</body>
</html>
