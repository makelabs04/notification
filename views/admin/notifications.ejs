<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8"/>
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title><%= title %> | PushNotify</title>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet"/>
  <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" rel="stylesheet"/>
  <link rel="stylesheet" href="/css/style.css"/>
</head>
<body>
<%- include('../partials/sidebar') %>
<div class="main-content">
  <%- include('../partials/topbar') %>
  <div class="page-body">
    <%- include('../partials/flash') %>

    <div class="card">
      <div class="card-header">
        <h3><i class="fas fa-history"></i> Notification History</h3>
        <a href="/admin/send-notification" class="btn btn-primary btn-sm">
          <i class="fas fa-plus"></i> New Notification
        </a>
      </div>
      <div class="card-body p-0">
        <% if (notifications.length === 0) { %>
          <div class="empty-state p-5">
            <i class="fas fa-bell-slash fa-3x" style="color:#ccc"></i>
            <p>No notifications have been sent yet.</p>
            <a href="/admin/send-notification" class="btn btn-primary">Send First Notification</a>
          </div>
        <% } else { %>
          <table class="table">
            <thead>
              <tr>
                <th>#</th>
                <th>Title</th>
                <th>Message</th>
                <th>Type</th>
                <th>Recipients</th>
                <th>Delivered</th>
                <th>Failed</th>
                <th>Sent By</th>
                <th>Date</th>
              </tr>
            </thead>
            <tbody>
              <% notifications.forEach((n, i) => { %>
              <tr>
                <td><%= i + 1 %></td>
                <td><strong><%= n.title %></strong></td>
                <td><%= n.body.substring(0, 60) %><%= n.body.length > 60 ? '...' : '' %></td>
                <td><span class="badge badge-<%= n.send_type %>"><%= n.send_type %></span></td>
                <td><span class="badge badge-muted"><%= n.total_recipients %></span></td>
                <td><span class="badge badge-success"><%= n.sent_count || 0 %></span></td>
                <td><span class="badge badge-danger"><%= n.failed_count || 0 %></span></td>
                <td><%= n.sent_by_name %></td>
                <td><%= new Date(n.created_at).toLocaleString() %></td>
              </tr>
              <% }) %>
            </tbody>
          </table>
        <% } %>
      </div>
    </div>
  </div>
</div>
</body>
</html>
